<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claration.ventricad</string>

    <key>ProgramArguments</key>
    <array>
        <string>/ventrica/live/usr/local/libexec/ventricad</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>/var/log/ventricad.log</string>

    <key>StandardErrorPath</key>
    <string>/var/log/ventricad.err</string>
</dict>
</plist>